# PhotoVault Frontend Environment Configuration
# Copy this file to .env for local Vite development.

# API endpoint (remote API in this workflow)
VITE_API_URL=https://vault-api.ekskog.net

# Optional UI metadata
VITE_APP_TITLE=EKSKOG PHOTOS
VITE_APP_DESCRIPTION=Secure Photo Gallery

# Optional feature flags
VITE_ENABLE_USER_MANAGEMENT=true
VITE_ENABLE_ALBUM_SHARING=false
VITE_ENABLE_PHOTO_COMMENTS=false

# Optional client behavior
VITE_MAX_UPLOAD_SIZE=20485760
VITE_THUMBNAIL_QUALITY=80
VITE_LAZY_LOADING=true

# Optional debugging
VITE_DEBUG_MODE=true
VITE_LOG_LEVEL=debug

# Optional bot protection
# Leave empty for local development unless you are testing Turnstile locally.
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

